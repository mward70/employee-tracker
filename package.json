{
    "name": "employee-tracker",
    "version": "1.0.0",
    "description": "A command-line application to manage a company's employee database using Node.js, Inquirer, and PostgreSQL.",
    "main": "app.js",
    "scripts": {
      "start": "node app.js",
      "dev": "nodemon app.js",
      "init-db": "psql -U postgres -f db/schema.sql",
      "seed-db": "psql -U postgres -f db/seeds.sql"
    },
    "dependencies": {
      "dotenv": "^16.3.1",
      "inquirer": "^9.2.1",
      "pg": "^8.11.1"
    },
    "devDependencies": {
      "nodemon": "^3.0.2"
    },
    "keywords": ["CLI", "Employee Management", "PostgreSQL", "Node.js"],
    "author": "Megan",
    "license": "MIT"
  }
  